#!/usr/bin/env ruby
# frozen_string_literal: true

# spread — static blog generator
#
# Usage:
#   bin/spread build              # Generate _site/ for deployment
#   bin/spread preview            # Build for local file:// browsing, open in browser
#   bin/spread new "Post title"   # Scaffold a new post
#
# Dependencies: ruby, kramdown (gem)

require 'yaml'
require 'erb'
require 'fileutils'
require 'time'
require 'json'
require 'kramdown'
require 'uri'

SPREAD_ROOT = File.expand_path('..', __dir__)
SITE_DIR    = File.join(SPREAD_ROOT, '_site')
CONTENT_DIR = File.join(SPREAD_ROOT, 'content')
TMPL_DIR    = File.join(SPREAD_ROOT, 'templates')
STATIC_DIR  = File.join(SPREAD_ROOT, 'static')
SITE_URL    = 'https://bioneural.com'
PROD_BASE   = URI.parse(SITE_URL).path.chomp('/')  # '' (root domain)

def log(msg)
  $stderr.puts "spread: #{msg}"
end

# -- Frontmatter parsing --

def parse_file(path)
  raw = File.read(path)
  if raw.start_with?("---\n") || raw.start_with?("---\r\n")
    closing = raw.index("\n---", 3)
    return { meta: {}, body_md: raw } unless closing
    yaml_str = raw[4...closing]
    meta = YAML.safe_load(yaml_str, permitted_classes: [Date, Time]) || {}
    body_md = raw[(closing + 4)..]&.lstrip || ''
  else
    meta = {}
    body_md = raw
  end
  { meta: meta, body_md: body_md }
end

# -- Template rendering --

def load_template(name)
  ERB.new(File.read(File.join(TMPL_DIR, name)))
end

# In deploy mode, base_path is '/spread' (absolute).
# In preview mode, base_path is a relative root like '.', '..', or '../..'.
$base_path = PROD_BASE

def base_path
  $base_path
end

# file:// needs explicit index.html; webservers resolve directories automatically
def idx
  @preview ? 'index.html' : ''
end

def render_layout(page_title:, description: nil, page_url: nil, jsonld: nil, og_image: nil, og_type: nil, &block)
  content = block.call
  layout = load_template('layout.html')
  layout.result(binding)
end

# -- Post body post-processing --

POST_PATTERN_VOCAB = [
  [/\Atl;?dr\z/i,        'tldr'],
  [/\Asetup\z/i,         'setup'],
  [/\Aexperiments?\z/i,  'experiment'],
  [/\Aresults?\z/i,      'results'],
  [/\Adead\s+ends?\z/i,  'dead-ends'],
  [/\Alimits?\z/i,       'limits']
].freeze

TLDR_PATTERN = %r{\A(\s*)<p>\s*<strong>TL;?DR</strong>\s*[—–\-:]?\s*(.+?)\s*</p>\s*}m

def strip_tags(html)
  html.gsub(/<[^>]+>/, '').gsub(/\s+/, ' ').strip
end

def tag_post_pattern(html)
  html.gsub(%r{<h2([^>]*)>(.+?)</h2>}m) do
    attrs, content = ::Regexp.last_match(1), ::Regexp.last_match(2)
    text = strip_tags(content)
    matched = POST_PATTERN_VOCAB.find { |re, _| text =~ re }
    if matched
      %{<h2#{attrs} data-post-section="#{matched[1]}">#{content}</h2>}
    else
      %{<h2#{attrs}>#{content}</h2>}
    end
  end
end

def linkify_headings(html)
  html.gsub(%r{<(h[2-3])([^>]*)>(.+?)</\1>}m) do
    tag, attrs, content = ::Regexp.last_match(1), ::Regexp.last_match(2), ::Regexp.last_match(3)
    if attrs =~ /id="([^"]+)"/
      id = ::Regexp.last_match(1)
      %{<#{tag}#{attrs}><a class="heading-anchor" href="##{id}">#{content}</a></#{tag}>}
    else
      %{<#{tag}#{attrs}>#{content}</#{tag}>}
    end
  end
end

def add_code_lang_attr(html)
  html.gsub(%r{<code class="language-([\w+\-]+)">}) do
    lang = ::Regexp.last_match(1)
    %{<code class="language-#{lang}" data-lang="#{lang}">}
  end
end

def lift_tldr(html)
  if (m = TLDR_PATTERN.match(html))
    abstract = strip_tags(m[2])
    rest = html.sub(TLDR_PATTERN, '')
    section = %{<section class="post-tldr" role="doc-abstract" aria-label="TL;DR">\n  <p class="post-tldr-label">TL;DR</p>\n  <p>#{m[2]}</p>\n</section>}
    [rest, section, abstract]
  else
    [html, nil, nil]
  end
end

def extract_h2_index(html)
  results = []
  html.scan(%r{<h2([^>]*)>(.+?)</h2>}m).each do |attrs, content|
    id = attrs =~ /\sid="([^"]+)"/ ? ::Regexp.last_match(1) : nil
    next unless id
    results << { id: id, text: strip_tags(content) }
  end
  results
end

def extract_citations(html, current_slug)
  html.scan(%r{<a\s[^>]*href="(/posts/[^"#?]+/?)"})
      .map { |m| m[0] }
      .reject { |u| u =~ %r{/posts/#{Regexp.escape(current_slug)}/?\z} }
      .uniq
end

def post_jsonld(post)
  data = {
    '@context' => 'https://schema.org',
    '@type' => 'TechArticle',
    'headline' => post[:title],
    'datePublished' => post[:date].to_s,
    'url' => "#{SITE_URL}/posts/#{post[:slug]}/",
    'author' => {
      '@type' => 'Person',
      'name' => 'Vėtra Bioneural',
      'url' => "#{SITE_URL}/about/"
    },
    'publisher' => {
      '@type' => 'Organization',
      'name' => 'bioneural'
    }
  }
  data['description']    = post[:summary]  if post[:summary] && !post[:summary].empty?
  data['abstract']       = post[:abstract] if post[:abstract]
  data['dateModified']   = post[:revised].to_s if post[:revised]
  data['articleSection'] = post[:sections].map { |s| s[:text] } if post[:sections] && !post[:sections].empty?
  if post[:citations] && !post[:citations].empty?
    data['citation'] = post[:citations].map { |path| { '@type' => 'WebPage', 'url' => "#{SITE_URL}#{path}" } }
  end
  data
end

def escape_xml(text)
  text.to_s
    .gsub('&', '&amp;')
    .gsub('<', '&lt;')
    .gsub('>', '&gt;')
    .gsub('"', '&quot;')
    .gsub("'", '&apos;')
end

# -- Post loading --

def load_posts
  pattern = File.join(CONTENT_DIR, 'posts', '*.md')
  Dir.glob(pattern).map do |path|
    parsed = parse_file(path)
    meta = parsed[:meta]
    filename = File.basename(path, '.md')
    slug = filename.sub(/\A\d{4}-\d{2}-\d{2}-/, '')
    date = meta['date']
    date = Date.parse(date.to_s) unless date.is_a?(Date)
    desc = meta['description']
    if desc && desc =~ /\[.+?\]\(.+?\)|[*]{2}.+?[*]{2}|`.+?`/
      abort "spread: error: description in #{filename} contains markdown — descriptions must be plain text"
    end

    revised = meta['revised']
    revised = Date.parse(revised.to_s) if revised && !revised.is_a?(Date)

    rendered   = Kramdown::Document.new(parsed[:body_md], auto_ids: true).to_html
    tagged     = tag_post_pattern(rendered)
    linked     = linkify_headings(tagged)
    coded      = add_code_lang_attr(linked)
    sections   = extract_h2_index(coded)
    citations  = extract_citations(coded, slug)
    body, tldr_html, abstract = lift_tldr(coded)
    summary = abstract || desc

    {
      title: meta['title'] || slug,
      date: date,
      revised: revised,
      order: meta['order'] || 0,
      slug: slug,
      description: desc,
      summary: summary,
      body: body,
      tldr_html: tldr_html,
      abstract: abstract,
      sections: sections,
      citations: citations,
      path: path
    }
  end.sort_by { |p| [p[:date], p[:order]] }.reverse
end

def load_about
  path = File.join(CONTENT_DIR, 'about.md')
  return nil unless File.exist?(path)
  parsed = parse_file(path)
  { body: Kramdown::Document.new(parsed[:body_md]).to_html }
end

# -- Sitemap --

def write_sitemap(out_dir, posts, about)
  urls = []
  index_lastmod = (posts.map { |p| p[:revised] || p[:date] }.max || Date.today).iso8601
  urls << { loc: "#{SITE_URL}/", lastmod: index_lastmod, changefreq: 'weekly', priority: '1.0' }
  urls << { loc: "#{SITE_URL}/about/", lastmod: nil, changefreq: 'monthly', priority: '0.8' } if about
  posts.each do |post|
    lastmod = (post[:revised] || post[:date]).iso8601
    urls << { loc: "#{SITE_URL}/posts/#{post[:slug]}/", lastmod: lastmod, changefreq: 'monthly', priority: '0.7' }
  end

  xml = +"<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n"
  xml << "<urlset xmlns=\"http://www.sitemaps.org/schemas/sitemap/0.9\">\n"
  urls.each do |u|
    xml << "  <url>\n"
    xml << "    <loc>#{u[:loc]}</loc>\n"
    xml << "    <lastmod>#{u[:lastmod]}</lastmod>\n" if u[:lastmod]
    xml << "    <changefreq>#{u[:changefreq]}</changefreq>\n"
    xml << "    <priority>#{u[:priority]}</priority>\n"
    xml << "  </url>\n"
  end
  xml << "</urlset>\n"

  File.write(File.join(out_dir, 'sitemap.xml'), xml)
end

# -- OG cards --

CHROME_PATHS = [
  '/Applications/Google Chrome.app/Contents/MacOS/Google Chrome',
  '/Applications/Chromium.app/Contents/MacOS/Chromium',
  '/usr/bin/google-chrome',
  '/usr/bin/chromium',
  '/usr/bin/chromium-browser'
].freeze

def find_chrome
  ENV['CHROME_BIN'] || CHROME_PATHS.find { |p| File.executable?(p) }
end

def generate_og_cards(force: false)
  require 'tempfile'
  require 'cgi'
  chrome = find_chrome
  abort 'spread: error: no chrome/chromium binary found (set CHROME_BIN)' unless chrome

  posts = load_posts
  og_dir = File.join(STATIC_DIR, 'og')
  FileUtils.mkdir_p(og_dir)

  tmpl_path = File.join(TMPL_DIR, 'og-card.html')
  tmpl = ERB.new(File.read(tmpl_path))

  posts.each do |post|
    out_path = File.join(og_dir, "#{post[:slug]}.png")
    if !force && File.exist?(out_path) && File.mtime(out_path) >= File.mtime(post[:path]) && File.mtime(out_path) >= File.mtime(tmpl_path)
      next
    end

    title       = CGI.escapeHTML(post[:title])
    description = CGI.escapeHTML(post[:summary].to_s)
    date        = post[:date].strftime('%Y.%m.%d')

    html = tmpl.result(binding)

    Tempfile.create(['og-card', '.html']) do |f|
      f.write(html)
      f.flush
      cmd = [
        chrome,
        '--headless=new',
        '--disable-gpu',
        '--hide-scrollbars',
        '--no-sandbox',
        '--window-size=1200,630',
        "--screenshot=#{out_path}",
        "file://#{f.path}"
      ]
      system(*cmd, out: File::NULL, err: File::NULL)
    end

    log "og: generated #{post[:slug]}.png"
  end
end

# -- Build --

def build
  log 'building...'

  @build_stamp = Time.now.to_f.to_s

  tmp_dir = "#{SITE_DIR}.tmp"
  FileUtils.rm_rf(tmp_dir)
  FileUtils.mkdir_p(tmp_dir)

  posts = load_posts
  about = load_about

  # Render each post (depth 2: posts/slug/index.html)
  post_tmpl = load_template('post.html')
  posts.each do |post|
    $base_path = @preview ? '../..' : PROD_BASE
    dir = File.join(tmp_dir, 'posts', post[:slug])
    FileUtils.mkdir_p(dir)
    inner = post_tmpl.result(binding)
    jsonld = post_jsonld(post)
    og_card_path = File.join(STATIC_DIR, 'og', "#{post[:slug]}.png")
    og_image_url = File.exist?(og_card_path) ? "#{SITE_URL}/og/#{post[:slug]}.png" : nil
    html = render_layout(page_title: "#{post[:title]} — bioneural", description: post[:summary], page_url: "#{SITE_URL}/posts/#{post[:slug]}/", jsonld: jsonld, og_image: og_image_url, og_type: 'article') { inner }
    File.write(File.join(dir, 'index.html'), html)
  end

  # Render index (depth 0: index.html)
  $base_path = @preview ? '.' : PROD_BASE
  index_tmpl = load_template('index.html')
  inner = index_tmpl.result(binding)
  html = render_layout(page_title: 'bioneural', description: 'Architecture tradeoffs, debugging paths, and decisions that need room to develop.', page_url: "#{SITE_URL}/") { inner }
  File.write(File.join(tmp_dir, 'index.html'), html)

  # Render about (depth 1: about/index.html)
  if about
    $base_path = @preview ? '..' : PROD_BASE
    about_tmpl = load_template('about.html')
    dir = File.join(tmp_dir, 'about')
    FileUtils.mkdir_p(dir)
    inner = about_tmpl.result(binding)
    html = render_layout(page_title: 'About — bioneural', page_url: "#{SITE_URL}/about/") { inner }
    File.write(File.join(dir, 'index.html'), html)
  end

  # Generate RSS feed (always uses absolute URLs)
  $base_path = PROD_BASE
  site_url = SITE_URL
  feed_tmpl = load_template('feed.xml')
  feed = feed_tmpl.result(binding)
  File.write(File.join(tmp_dir, 'feed.xml'), feed)

  # Generate sitemap.xml (always uses absolute URLs)
  write_sitemap(tmp_dir, posts, about)

  # Render 404 page (depth 0)
  $base_path = @preview ? '.' : PROD_BASE
  error_tmpl = load_template('404.html')
  inner = error_tmpl.result(binding)
  html = render_layout(page_title: '404 — bioneural') { inner }
  File.write(File.join(tmp_dir, '404.html'), html)

  # Copy static assets
  Dir.glob(File.join(STATIC_DIR, '**', '*')).each do |src|
    next if File.directory?(src)
    rel = src.sub("#{STATIC_DIR}/", '')
    dest = File.join(tmp_dir, rel)
    FileUtils.mkdir_p(File.dirname(dest))
    FileUtils.cp(src, dest)
  end

  # Copy CNAME for GitHub Pages custom domain
  cname = File.join(SPREAD_ROOT, 'CNAME')
  FileUtils.cp(cname, tmp_dir) if File.exist?(cname)

  # Write build timestamp for hot-reload polling
  File.write(File.join(tmp_dir, '.build'), @build_stamp) if @preview

  # Atomic swap
  old_dir = "#{SITE_DIR}.old"
  FileUtils.rm_rf(old_dir)
  File.rename(SITE_DIR, old_dir) if File.exist?(SITE_DIR)
  File.rename(tmp_dir, SITE_DIR)
  FileUtils.rm_rf(old_dir)

  log "built → #{SITE_DIR}/"
end

# -- Local build --

def local_build
  @preview = true
  build
end

# -- Preview --

def preview
  @preview = true
  build
  index = File.join(SITE_DIR, 'index.html')
  system('open', index)
  log "opened #{index}"
  log "pages auto-refresh every 2s — run 'bin/spread build local' after edits"
end

# -- New post --

def new_post(title)
  slug = title.downcase.strip.gsub(/[^a-z0-9]+/, '-').gsub(/\A-|-\z/, '')
  date = Time.now.strftime('%Y-%m-%d')
  filename = "#{date}-#{slug}.md"
  path = File.join(CONTENT_DIR, 'posts', filename)

  if File.exist?(path)
    log "already exists: #{path}"
    exit 1
  end

  File.write(path, <<~MD)
    ---
    title: "#{title}"
    date: #{date}
    description: ""
    ---

  MD

  log "created #{path}"
end

# -- Entry --

case ARGV[0]
when 'build'
  if ARGV[1] == 'local'
    local_build
  else
    build
  end
when 'preview'
  preview
when 'new'
  title = ARGV[1]
  unless title && !title.empty?
    $stderr.puts 'usage: bin/spread new "Post title"'
    exit 1
  end
  new_post(title)
when 'og'
  generate_og_cards(force: ARGV.include?('--force'))
else
  $stderr.puts 'usage: bin/spread [build|preview|new "title"|og [--force]]'
  exit 1
end
